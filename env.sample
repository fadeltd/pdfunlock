# UPX Compression Configuration
# Copy this file to .env and modify as needed

# Enable UPX compression for Linux builds (true/false)
ENABLE_UPX_LINUX=true

# Enable UPX compression for Windows builds (true/false)
ENABLE_UPX_WINDOWS=true

# Enable UPX compression for macOS Intel builds (true/false)
ENABLE_UPX_DARWIN_INTEL=true

# Enable UPX compression for macOS ARM builds (true/false)
# Note: UPX may have compatibility issues with macOS ARM binaries
ENABLE_UPX_DARWIN_ARM=false

# Global UPX enable/disable (set to false to disable all UPX compression)
ENABLE_UPX=true

# GitHub repository owner (used by GoReleaser)
GITHUB_REPOSITORY_OWNER=fadeltd